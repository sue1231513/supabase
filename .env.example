# Supabase Personal Access Token
# 去 https://supabase.com/dashboard/account/tokens 生成
# 因为 PAT 是账号级别的,只要 sue1231511 这个账号同时是两个组织的成员,
# 一个 token 就能同时访问 "sue1231511's" 和 "橘瓣插件" 两个组织下的所有项目
SUPABASE_PAT=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 这个 MCP 服务对外暴露的密钥,防止别人拿到 URL 就能操作你的 Supabase。
# claude.ai 添加自定义连接器时,URL 后面拼上 ?key=你设置的这个值
# 例如: https://your-app.zeabur.app/mcp?key=一个自己随便定的高强度字符串
MCP_PROXY_SECRET=换成一个自己定的高强度随机字符串

# ── OAuth 持久化存储（新增，与 SUPABASE_PAT 是完全不同用途的两套凭据，别搅混）──
# SUPABASE_PAT 是"用来管理你账号下多个 Supabase 组织/项目"的账号级令牌；
# 下面这两个是"用来把本服务自己的 OAuth client/token 数据存进一张表"的项目级凭据，
# 指向的是「晏安的数据库」这个具体项目，跟 zeabur-mcp 仓库共用同一张表 mcp_oauth_store。
#
# Project URL，去 Supabase Dashboard 该项目 Settings → API 里拿
OAUTH_STORE_SUPABASE_URL=https://segsimuoukrovxrgbjfw.supabase.co
# service_role key（不是 anon key！），同样在 Settings → API 里，默认隐藏需要点开
OAUTH_STORE_SUPABASE_SERVICE_ROLE_KEY=换成「晏安的数据库」项目的 service_role key

# 本地调试用,Zeabur 部署时会自动注入 PORT,不用手动设置
PORT=3000
